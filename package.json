    "lightningcss": "^1.32.0",
    "lucide-react": "^1.20.0",
    "next": "16.2.9",
    "nodemailer": "^9.0.0",
    "prisma": "^5.22.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.6.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
