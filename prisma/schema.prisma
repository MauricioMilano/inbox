generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  passwordHash   String
  name           String?
  resetToken     String?
  resetTokenExp  DateTime?
  
  // SMTP Settings (opcional - cada usuário configura o seu)
  smtpEnabled    Boolean  @default(false)
  smtpHost      String?
  smtpPort      Int      @default(587)
  smtpSecure    Boolean  @default(true)  // true = TLS, false = STARTTLS
  smtpUser      String?
  smtpPass      String?  // Criptografado em produção
  smtpFromEmail String?
  smtpFromName  String?
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  sites Site[]
}

model Site {
  id                  String   @id @default(cuid())
  userId              String
  name                String
  domain              String
  notificationEmail   String
  logoPath            String?
  token               String   @unique @default(cuid())
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages Message[]
}

model Message {
  id          String   @id @default(cuid())
  siteId      String
  status      String   @default("nova") // nova, lida, respondida, arquivada, spam
  senderName  String?
  senderEmail String?
  senderPhone String?
  subject     String?
  content     String?
  metadata    String?  // JSON com IP, user agent, referrer, etc
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)
}
